#include <stdio.h>
#include <time.h>
#include <stdlib.h>
#define N 100

void sort_arr(int *arr,int n);
void getarr(int *arr);
void print(int *arr,int n);
int index_arr(int *arr,int m);
int main()
{
    int m;
    int a[N];
    printf("随机生成%d个整数:\n",N);
    getarr(a);
    print(a,N);
    printf("排序后:\n");
    sort_arr(a,N);
    print(a,N);
    printf("请输入需要查找的整数:\n");
    scanf("%d",&m);
    index_arr(a,m);
    printf("查找的数据在下标为%d位置\n", index_arr(a,m));
    return 0;
}
void getarr(int *arr)
{
    int i;
    srand(time(0));
    for(i=0;i<N;i++)
    {
        arr[i]=rand()%1000;
    }
}
void print(int *arr,int n)
{
    int i;
    for(i=0;i<n;i++)
    {
        printf("%4d ",arr[i]);
        if((i+1)%10==0)
        printf("\n");
    }    
}
void sort_arr(int *arr,int n)
{
    int i,j,temp,m;
    for(i=0;i<n;i++)
    {
        m=i;
        for(j=i;j<n;j++)
        {
            if(arr[j]<arr[m])
            {
                m=j;
            }
        }
        if(m!=i)
        {
            temp=arr[m];
            arr[m]=arr[i];
            arr[i]=temp;
        }
    }
}
int index_arr(int *arr,int m)
{
    int i;
    for(i=0;i<N;i++)
    {
        if(arr[i]==m)
        {
            return i;
        }
    }
}
